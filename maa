#!/usr/bin/env bash
# maa — MAA CLI entrypoint
#
# Usage:
#   maa review frontend        <project-path>  Run a frontend standards review
#   maa review backend         <project-path>  Run a Node.js backend standards review
#   maa review backend-python  <project-path>  Run a Python backend standards review
#   maa review api-design      <project-path>  Run an API design standards review
#   maa review security        <project-path>  Run a security hygiene review
#   maa review testing         <project-path>  Run a cross-cutting testing review
#   maa help                                   Show this help message
#
# All commands route to scripts/ — edit the scripts directly to change behaviour.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

usage() {
  cat <<EOF
maa — My Automated Advisor

Usage:
  maa review frontend        <project-path>  Run a frontend standards review
  maa review backend         <project-path>  Run a Node.js backend standards review
  maa review backend-python  <project-path>  Run a Python backend standards review
  maa review api-design      <project-path>  Run an API design standards review
  maa review security        <project-path>  Run a security hygiene review
  maa review testing         <project-path>  Run a cross-cutting testing review
  maa help                                   Show this help

Examples:
  maa review frontend        ~/projects/my-app
  maa review backend         ~/projects/my-node-api
  maa review backend-python  ~/projects/my-python-api
  maa review api-design      ~/projects/my-api
  maa review security        ~/projects/my-api
  maa review testing         ~/projects/my-api

Reports are saved to reports/reviews/ in this repo.
EOF
}

# ---------------------------------------------------------------------------
# Routing
# ---------------------------------------------------------------------------

COMMAND="${1:-help}"

case "$COMMAND" in
  review)
    DOMAIN="${2:-}"
    if [[ -z "$DOMAIN" ]]; then
      echo "Error: missing domain. Usage: maa review <domain> <project-path>" >&2
      echo "Available domains: frontend, backend, backend-python, api-design, security, testing" >&2
      exit 1
    fi

    PROJECT_PATH="${3:-}"
    if [[ -z "$PROJECT_PATH" ]]; then
      echo "Error: missing project path. Usage: maa review $DOMAIN <project-path>" >&2
      exit 1
    fi

    case "$DOMAIN" in
      frontend)
        exec "$REPO_ROOT/scripts/maa-review.sh" "$PROJECT_PATH"
        ;;
      backend)
        exec "$REPO_ROOT/scripts/maa-backend-review.sh" "$PROJECT_PATH"
        ;;
      backend-python)
        exec "$REPO_ROOT/scripts/maa-backend-python-review.sh" "$PROJECT_PATH"
        ;;
      api-design)
        exec "$REPO_ROOT/scripts/maa-api-design-review.sh" "$PROJECT_PATH"
        ;;
      security)
        exec "$REPO_ROOT/scripts/maa-security-review.sh" "$PROJECT_PATH"
        ;;
      testing)
        exec "$REPO_ROOT/scripts/maa-testing-review.sh" "$PROJECT_PATH"
        ;;
      *)
        echo "Error: unknown domain '$DOMAIN'. Available domains: frontend, backend, backend-python, api-design, security, testing" >&2
        exit 1
        ;;
    esac
    ;;

  help|--help|-h)
    usage
    ;;

  *)
    echo "Error: unknown command '$COMMAND'" >&2
    echo ""
    usage
    exit 1
    ;;
esac
